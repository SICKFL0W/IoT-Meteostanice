        "func": "  //Přístup k datům z datové části zprávy\n  const { teplota, vlhkost, tlak, nadmorska_vyska, nazev_zarizeni, nazev_wifi } = msg.payload;\n\n  // Message payload\n  msg.payload = {\n    teplota: { aktual: teplota },\n    vlhkost: { aktual: vlhkost },\n    tlak: { aktual: tlak },\n    nvyska: { aktual: nadmorska_vyska },\n    nazevazrizeni: { aktual: nazev_zarizeni},\n    ssid: {aktual: nazev_wifi}\n  };\n\n  //Vrácení modifikované zprávy\n  return msg;\n",
